{
  "adsb": {
    "url": "http://localhost:8080/data/aircraft.json",
    "pollIntervalMs": 2000
  },
  "tracker": {
    "horizonS": 300,
    "stepS": 0.5,
    "thresholdDeg": 0.3,
    "looseThresholdDeg": 5.0,
    "bodies": ["Sun", "Moon"]
  },
  "pushover": {
    "token": "PASTE_PUSHOVER_APP_TOKEN_HERE",
    "user":  "PASTE_PUSHOVER_USER_KEY_HERE",
    "device": "",
    "enabled": false,
    "minStage": "radio"
  },
  "lifecycle": {
    "plannedWindowMs": 3600000,
    "imminentWindowMs": 30000,
    "staleGraceMs": 10000
  },
  "server": {
    "port": 8081,
    "host": "0.0.0.0",
    "publicUrl": ""
  },
  "store": {
    "path": "./data/history.db"
  },
  "routes": {
    "enabled": true,
    "ttlMs": 3600000,
    "negativeTtlMs": 300000
  },
  "predictor": {
    "enabled": true,
    "daysBack": 14,
    "minRepeats": 2,
    "bucketMinutes": 60,
    "rebuildIntervalMs": 3600000,
    "lookAheadMs": 86400000
  },
  "opensky": {
    "enabled": false,
    "airports": ["EDDF", "EDDL", "EHAM"],
    "lookbackDays": 7
  }
}
